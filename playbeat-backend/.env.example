# Copy this to .env and fill in real values (DO NOT commit secrets)
# Local development example for PlayBeat backend

# Server
NODE_ENV=development
PORT=5000

# MongoDB — replace <username> and <password> with your credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.ejlpfar.mongodb.net/?appName=Cluster0

# JWT secret
JWT_SECRET=change_this_to_a_secure_random_string

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Stripe (if used)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# ─── SERVER ──────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MONGODB ─────────────────────────────────────────────
# Paste your MongoDB Atlas connection string here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/playbeat?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=8h

# ─── ADMIN CREDENTIALS (initial seed) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=playbeat2026

# ─── STRIPE ──────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── JAZZCASH ────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_password
JAZZCASH_HASH_KEY=your_hash_key
JAZZCASH_RETURN_URL=https://playbeat-backend.onrender.com/api/payments/jazzcash/callback

# ─── EASYPAISA ───────────────────────────────────────────
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key

# ─── BANK ALFALAH ────────────────────────────────────────
ALFALAH_USERNAME=your_username
ALFALAH_PASSWORD=your_password
ALFALAH_HASH_KEY1=your_key1
ALFALAH_HASH_KEY2=your_key2
ALFALAH_MERCHANT_ID=197
ALFALAH_STORE_ID=000001
ALFALAH_CHANNEL_ID=1002

# ─── MEEZAN BANK ─────────────────────────────────────────
MEEZAN_USERNAME=your_username
MEEZAN_PASSWORD=your_password
MEEZAN_IBAN=PK86MEZN0015040115102971

# ─── CORS / FRONTEND ─────────────────────────────────────
ALLOWED_ORIGINS=https://playbeat.digital,https://admin.playbeat.digital,http://localhost:3000
